@model IEnumerable<opimerchant.Models.User>

<div>
	<div>
		<table class="table table-hover">
			<thead>
				<tr>
					<th>UserName</th>
					<th>Bio</th>
					<th>Profile Picture</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var user in Model)
				{
					if (user != null)
					{
						@*(user.UserName.ToString());*@
						<tr>
							<td>@user.UserName</td>
							<td>@user.Bio</td>
							<td>
								<img style="width: 100px; height: 100px;" src="~/images/@user.ProfilePicture" alt="profile picture" />
							</td>
						</tr>
					}
					else
					{
						@("no data, is null");
					}

				}
			</tbody>
		</table>

	</div>
</div>
