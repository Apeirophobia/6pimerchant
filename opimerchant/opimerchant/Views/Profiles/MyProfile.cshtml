@using Microsoft.AspNetCore.Identity
@inject SignInManager<opimerchant.Models.User> _signInManager;

<div>

	<a class="btn btn-primary" asp-action="Edit" asp-controller="Profiles" asp-route-id="@ViewBag.loggedUser.Id">Edit data</a>
	<div>
		<table class="table table-hover">
			<thead>
				<tr>
					<th>UserName</th>
					<th>Bio</th>
					<th>Profile Picture</th>
				</tr>
			</thead>
			<tbody>
				<tr>
					<td>@ViewBag.loggedUser.UserName</td>
					<td>@ViewBag.loggedUser.Bio</td>
					<td>
						<img style="width: 100px; height: 100px;" src="~/images/@ViewBag.loggedUser.ProfilePicture" alt="profile picture" />
					</td>
				</tr>
			</tbody>
		</table>

	</div>
</div>
