@model opimerchant.Models.Post

<h1>Delete Post</h1>
<p>Are you sure you want to delete this post?</p>

<dl class="row">
	<dt class="col-sm-2">Author</dt>
	<dd class="col-sm-10">@Html.DisplayFor(m => m.Author)</dd>

	<dt class="col-sm-2">Title</dt>
	<dd class="col-sm-10">@Html.DisplayFor(m => m.Title)</dd>

	<dt class="col-sm-2">Description</dt>
	<dd class="col-sm-10">@Html.DisplayFor(m => m.Description)</dd>

	<dt class="col-sm-2">Body</dt>
	<dd class="col-sm-10">@Html.DisplayFor(m => m.Body)</dd>
</dl>

<form asp-action="Delete" asp-controller="Posts" method="post">
	<input type="hidden" name="id" value="@Model.PostID" />
	<button type="submit" class="btn btn-danger">Delete</button>
	<a asp-action="Index" asp-controller="Posts" class="btn btn-secondary">Cancel</a>
</form>
